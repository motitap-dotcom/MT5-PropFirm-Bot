# WhatsApp Service Configuration
# Copy this file to .env and fill in your values:
#   cp .env.template .env

# Permanent token from Meta Business Settings > System Users
WHATSAPP_TOKEN=your_permanent_token_here

# Phone Number ID from Meta App > WhatsApp > API Setup
WHATSAPP_PHONE_ID=your_phone_number_id_here

# Your personal WhatsApp number (with country code, no + or spaces)
# Example: 972501234567
MY_PHONE_NUMBER=your_phone_number_here
