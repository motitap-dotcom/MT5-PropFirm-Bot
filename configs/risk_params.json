{
  "_mode": "LIVE_CHALLENGE",
  "_warning": "These are TIGHTENED parameters for real money challenge",

  "risk_per_trade_percent": 0.5,
  "max_risk_per_trade_percent": 0.75,
  "min_risk_per_trade_percent": 0.25,
  "max_open_positions": 2,
  "max_daily_trades": 8,
  "max_consecutive_losses": 5,
  "min_risk_reward_ratio": 2.0,

  "drawdown_guards": {
    "hard_daily_dd_percent": 5.0,
    "hard_total_dd_percent": 10.0,
    "soft_daily_dd_percent": 3.0,
    "critical_daily_dd_percent": 4.0,
    "soft_total_dd_percent": 7.0,
    "critical_total_dd_percent": 9.0,
    "_note": "Soft=halt new trades | Critical=close all | Hard=prop firm limit (never touch)"
  },

  "spread_filter": {
    "major_pairs_max_pips": 2.5,
    "xauusd_max_pips": 4.0,
    "spread_anomaly_multiplier": 3.0
  },

  "news_filter": {
    "minutes_before": 30,
    "minutes_after": 30,
    "filter_high_impact": true,
    "filter_medium_impact": false
  },

  "trailing_stop": {
    "activation_pips": 30,
    "trail_distance_pips": 20
  },

  "breakeven": {
    "activation_pips": 20,
    "offset_pips": 2
  },

  "session_filter": {
    "london_start_utc": "07:00",
    "london_end_utc": "11:00",
    "newyork_start_utc": "12:00",
    "newyork_end_utc": "16:00"
  },

  "weekend_guard": {
    "close_all_day": 5,
    "close_all_hour_utc": 20
  },

  "flash_crash_guard": {
    "max_equity_drop_pct_per_tick": 2.0,
    "connection_timeout_seconds": 120
  },

  "caution_mode": {
    "_note": "When approaching DD limits, lot size is halved automatically",
    "trigger_at_percent_of_soft_limit": 60
  }
}
