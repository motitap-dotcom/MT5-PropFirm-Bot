{
  "_mode": "FUNDED_INSTANT_AGGRESSIVE",
  "_warning": "Active trading mode for 6% trailing DD - Stellar Instant. Guardian protects the hard limit.",

  "risk_per_trade_percent": 1.0,
  "max_risk_per_trade_percent": 1.5,
  "min_risk_per_trade_percent": 0.5,
  "max_open_positions": 4,
  "max_daily_trades": 15,
  "max_consecutive_losses": 6,
  "min_risk_reward_ratio": 1.2,

  "drawdown_guards": {
    "hard_total_dd_percent": 6.0,
    "soft_total_dd_percent": 4.8,
    "critical_total_dd_percent": 5.3,
    "trailing_drawdown": true,
    "_note": "6% TRAILING DD. Soft=halt new trades at 4.8% | Critical=close all at 5.3% | Hard=6% account blown"
  },

  "spread_filter": {
    "major_pairs_max_pips": 4.0,
    "xauusd_max_pips": 7.0,
    "spread_anomaly_multiplier": 3.0
  },

  "news_filter": {
    "minutes_before": 10,
    "minutes_after": 10,
    "filter_high_impact": true,
    "filter_medium_impact": false,
    "_note": "FundedNext caps profit at 40% for trades within 5 min of news"
  },

  "trailing_stop": {
    "activation_pips": 20,
    "trail_distance_pips": 12
  },

  "breakeven": {
    "activation_pips": 15,
    "offset_pips": 2
  },

  "session_filter": {
    "london_start_utc": "06:00",
    "london_end_utc": "17:00",
    "newyork_start_utc": "12:00",
    "newyork_end_utc": "23:00"
  },

  "weekend_guard": {
    "close_all_day": 5,
    "close_all_hour_utc": 20
  },

  "flash_crash_guard": {
    "max_equity_drop_pct_per_tick": 2.0,
    "connection_timeout_seconds": 120
  },

  "caution_mode": {
    "_note": "When approaching DD limits, lot size is halved automatically",
    "trigger_at_percent_of_soft_limit": 80
  },

  "consistency_rule": {
    "enabled": true,
    "max_single_day_profit_percent": 40,
    "_note": "No single day can be more than 40% of total profit for payout eligibility"
  }
}
