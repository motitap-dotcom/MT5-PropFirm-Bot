{
  "_mode": "FUNDED_INSTANT",
  "_strategy": "v4.0 Trend + Momentum - H1 EMA50 trend filter + M15 EMA/RSI/MACD",

  "risk_per_trade_percent": 0.75,
  "max_risk_per_trade_percent": 1.0,
  "min_risk_per_trade_percent": 0.25,
  "max_open_positions": 3,
  "max_daily_trades": 10,
  "max_consecutive_losses": 6,
  "min_risk_reward_ratio": 1.5,

  "drawdown_guards": {
    "hard_total_dd_percent": 6.0,
    "soft_total_dd_percent": 4.0,
    "critical_total_dd_percent": 5.2,
    "trailing_drawdown": true,
    "_note": "6% TRAILING DD. Soft=halt new trades at 4% | Critical=close all at 5.2% | Hard=6% account blown"
  },

  "spread_filter": {
    "major_pairs_max_pips": 3.5,
    "xauusd_max_pips": 5.0,
    "spread_anomaly_multiplier": 3.0
  },

  "news_filter": {
    "minutes_before": 10,
    "minutes_after": 10,
    "filter_high_impact": true,
    "filter_medium_impact": false,
    "_note": "Reduced from 30/30 to 10/10 - less blackout time"
  },

  "trailing_stop": {
    "mode": "ATR",
    "activation_atr_mult": 1.0,
    "trail_distance_atr_mult": 0.8,
    "_note": "ATR-based: activate at 1x ATR profit, trail at 0.8x ATR"
  },

  "breakeven": {
    "mode": "ATR",
    "activation_atr_mult": 0.7,
    "offset_pips": 2,
    "_note": "Move to breakeven when 0.7x ATR in profit"
  },

  "signal_params": {
    "strategy": "TREND_MOMENTUM",
    "ema_fast": 8,
    "ema_slow": 21,
    "rsi_period": 14,
    "atr_period": 14,
    "macd": "12,26,9",
    "htf_ema": 50,
    "rsi_buy_range": "35-68",
    "rsi_sell_range": "32-65",
    "atr_sl_multiplier": 1.5,
    "atr_tp_multiplier": 3.0,
    "_note": "2:1 RR minimum (TP/SL = 3.0/1.5 = 2.0)"
  },

  "session_filter": {
    "start_utc": "07:00",
    "end_utc": "21:00",
    "_note": "Continuous London+NY coverage: 14 hours/day"
  },

  "weekend_guard": {
    "close_all_day": 5,
    "close_all_hour_utc": 20
  },

  "flash_crash_guard": {
    "max_equity_drop_pct_per_tick": 2.0,
    "connection_timeout_seconds": 120
  },

  "caution_mode": {
    "_note": "When approaching DD limits, lot size is halved automatically",
    "trigger_at_percent_of_soft_limit": 85
  },

  "consistency_rule": {
    "enabled": true,
    "max_single_day_profit_percent": 40,
    "_note": "No single day can be more than 40% of total profit for payout eligibility"
  }
}
